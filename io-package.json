  "native": {
    "pollIntervalSeconds": 30,
    "commandTimeoutMs": 5000,
    "operatorId": "",
    "discoveryEnabled": true,
    "discoveryTimeoutMs": 5000,
    "discoveryScanPorts": [
      51443
    ],
    "discoverySubnets": "",
    "devices": []
